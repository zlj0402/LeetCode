{
  "env": {
    "ANTHROPIC_AUTH_TOKEN": "YOUR_TOKEN_HERE",
    "ANTHROPIC_BASE_URL": "https://coding.dashscope.aliyuncs.com/apps/anthropic",
    "ANTHROPIC_SMALL_FAST_MODEL": "qwen3.7-plus",
    "ANTHROPIC_DEFAULT_HAIKU_MODEL": "qwen3.7-plus",
    "ANTHROPIC_DEFAULT_SONNET_MODEL": "qwen3.7-plus",
    "ANTHROPIC_DEFAULT_OPUS_MODEL": "qwen3.7-plus",
    "CLAUDE_CODE_SUBAGENT_MODEL": "qwen3.7-plus",

    "ANTHROPIC_MODEL": "qwen3.7-plus[1m]",  // 指定默认模型，加 [1m] 表示开启 qwen 系列模型的 1M 上下文，默认是 20w
		"CLAUDE_CODE_AUTO_COMPACT_WINDOW": "800000", // 配合 1M 上下文，在 80w 时开启自动压缩，默认是 20w
		"DISABLE_AUTOUPDATER": "1",  // 关闭自动更新
		"CLAUDE_CODE_NO_FLICKER": "1",  // 开启终端内全屏模式，放置界面乱跳
		"CLAUDE_CODE_ATTRIBUTION_HEADER": "0"  // 提高缓存利用率
  }
}